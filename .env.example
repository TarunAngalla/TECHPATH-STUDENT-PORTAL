DATABASE_URL=postgresql://techpath:techpath@localhost:5432/techpath
# Required in every environment. Generate at least 32 random characters.
SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-characters
# Optional separate salt for hashed public rate-limit keys. Falls back to SESSION_SECRET.
RATE_LIMIT_HASH_SECRET=replace-with-another-long-random-secret
ADMIN_EMAIL_DOMAIN=thetechpath.com
ADMIN_NOTIFICATION_EMAIL=admin@thetechpath.com
LEAD_INTAKE_SECRET=replace-with-a-long-random-shared-secret
RESEND_API_KEY=
EMAIL_FROM=The Tech Path <onboarding@thetechpath.com>
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DOCUMENTS_BUCKET=documents
NEXT_PUBLIC_CANDIDATE_HOST=portal.localhost:3000
NEXT_PUBLIC_CANDIDATE_PORTAL_URL=http://portal.localhost:3000
NEXT_PUBLIC_ADMIN_HOST=admin.localhost:3000

# Enquiry and invitation controls.
CANDIDATE_INVITE_TTL_HOURS=48
PUBLIC_ENQUIRY_IP_LIMIT=8
PUBLIC_ENQUIRY_EMAIL_LIMIT=3
PUBLIC_ENQUIRY_RATE_WINDOW_MINUTES=60
PUBLIC_ENQUIRY_REAPPLICATION_DAYS=30
ALLOW_APPROVAL_WITHOUT_CONSULTATION=false

# Secure invitations are the only supported candidate account-setup path.
ENABLE_SECURE_INVITES=true
# Keep false until Phase 3 NDA signing is complete and verified.
ENABLE_NDA_GATE=false
ENABLE_CANDIDATE_APPLICATION_COMMENTS=false
ENABLE_CANDIDATE_RESUME_UPLOAD=false
ENABLE_CANDIDATE_TRAINING_SELF_COMPLETE=false
ENABLE_CANDIDATE_PHONE_EDIT=false
